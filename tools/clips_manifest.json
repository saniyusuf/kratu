 "act_desc_colors": {
  "text": "Launuka. A nan za mu koyi launuka da Turanci.",
  "lang": "ha"
 },
 "act_desc_shapes": {
  "text": "Siffofi. A nan za mu koyi siffofi da Turanci.",
  "lang": "ha"
 },
 "act_desc_numbers": {
  "text": "Lambobi. A nan za a nuna yatsun hannu, mu koyi ƙidaya da Turanci.",
  "lang": "ha"
 },
 "act_desc_quiz": {
  "text": "Nemo hoto. Za a faɗi sunan abu, sannan a danna hotonsa.",
  "lang": "ha"
 },
 "act_desc_read": {
  "text": "Karatu. A nan za mu karanta kalmomi, harafi-harafi.",
  "lang": "ha"
 },
 "cat_start_colors": {
  "text": "Yanzu za mu koyi launuka. Za mu faɗi sunayensu da Turanci.",
  "lang": "ha"
 },
 "cat_start_shapes": {
  "text": "Yanzu za mu koyi siffofi. Za mu faɗi sunayensu da Turanci.",
  "lang": "ha"
 },
 "cat_start_numbers": {
  "text": "Yanzu za mu koyi ƙidaya. Za a nuna yatsun hannu. A ƙirga yatsun da aka ɗaga, sannan a faɗi lambar da Turanci.",
  "lang": "ha"
 },
 "quiz_intro": {
  "text": "Saurara da kyau! Za a faɗi sunan abu da Turanci, sannan a danna hotonsa.",
  "lang": "ha"
 },
 "quiz_tap": {
  "text": "Danna hoton abin da aka faɗa.",
  "lang": "ha"
 },
 "quiz_wrong": {
  "text": "A'a, ba wannan ba. A sake saurara, a sake gwadawa.",
  "lang": "ha"
 },
 "read_intro": {
  "text": "Ga kalma. Za mu karanta ta tare, harafi-harafi.",
