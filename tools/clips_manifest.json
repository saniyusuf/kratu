 },
 "read_word": {
  "text": "Yanzu, a karanta kalmar gaba ɗaya, da babbar murya.",
  "lang": "ha"
 },
 "read_good": {
  "text": "Madalla! Ka iya karatu!",
  "lang": "ha"
